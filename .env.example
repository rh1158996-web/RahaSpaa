# ─────────────────────────────────────────────
# Raha Spa — Environment Variables Template
# Copy this to .env for local development
# Set these in Vercel Dashboard > Settings > Environment Variables for production
# ─────────────────────────────────────────────

# Database — MUST be a remote host on Vercel (not localhost)
# Recommended free providers: PlanetScale, Railway, Clever Cloud, Aiven
DB_HOST=your-mysql-host.example.com
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=raha_spa

# Session secret — change to a long random string for production
SESSION_SECRET=change_this_to_a_long_random_secret_string

# Node environment
NODE_ENV=production

# Port — only used locally; Vercel sets this automatically
PORT=3000
